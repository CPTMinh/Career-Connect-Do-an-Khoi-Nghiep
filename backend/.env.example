# Copy file này thành .env và điền giá trị thật (KHÔNG commit .env lên Git)

# PostgreSQL — có thể lấy free tier từ Railway/Render/Supabase
DATABASE_URL="postgresql://user:password@localhost:5432/career_connect?schema=public"

# JWT
JWT_SECRET="doi-chuoi-nay-thanh-random-string-that-dai"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Email service (SendGrid hoặc SMTP thường)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Career Connect <no-reply@careerconnect.dev>"

# Google Meet / Calendar (Phase sau, để trống trong MVP nếu chưa setup)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
